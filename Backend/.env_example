# ─────────────────────────────────────────────
#  Application – .env_example
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
# Main application database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── Security ─────────────────────────────────
# Long, random secret string used to sign JWT tokens
SECRET_KEY=your-very-secret-key-change-me

# ── Embeddings (RAG) — server-wide OpenAI key, not per-tenant ───────────────
# Required for document processing and vector search. Chat LLM keys are set in Admin UI.
OPENAI_API_KEY=sk-...

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080  # 7 days



